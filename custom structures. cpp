#include <iostream>
#include <algorithm>   // std::copy
#include <stdexcept>   // std::out_of_range
using namespace std;
// ----------------------------------------------------------
//  List
// ----------------------------------------------------------
class List {
private:
    int* data;
    int size;
    int capacity;

    void resize() {
        int newCapacity = (capacity == 0) ? 4 : capacity * 2;

        int* newData = new int[newCapacity];
        std::copy(data, data + size, newData);

        delete[] data;
        data = newData;
        capacity = newCapacity;
    }

public:
    List() : data(new int[4]), size(0), capacity(4) {}

    // Copy constructor
    List(const List& other)
        : data(new int[other.capacity]),
          size(other.size),
          capacity(other.capacity) {
        std::copy(other.data, other.data + size, data);
    }

    // Copy assignment (exception-safe hơn)
    List& operator=(const List& other) {
        if (this == &other) return *this;

        int* newData = new int[other.capacity];
        std::copy(other.data, other.data + other.size, newData);

        delete[] data;

        data = newData;
        size = other.size;
        capacity = other.capacity;

        return *this;
    }

    // Move constructor
    List(List&& other) noexcept
        : data(other.data),
          size(other.size),
          capacity(other.capacity) {
        other.data = nullptr;
        other.size = 0;
        other.capacity = 0;
    }

    // Move assignment
    List& operator=(List&& other) noexcept {
        if (this == &other) return *this;

        delete[] data;

        data = other.data;
        size = other.size;
        capacity = other.capacity;

        other.data = nullptr;
        other.size = 0;
        other.capacity = 0;

        return *this;
    }

    ~List() {
        delete[] data;
    }

    // O(1) amortized
    void pushBack(int val) {
        if (size == capacity)
            resize();

        data[size++] = val;
    }

    // O(1)
    void popBack() {
        if (size > 0)
            --size;
    }

    // O(n)
    void insert(int idx, int val) {
        if (idx < 0 || idx > size)
            throw out_of_range("Index out of range");

        if (size == capacity)
            resize();

        for (int i = size; i > idx; --i)
            data[i] = data[i - 1];

        data[idx] = val;
        ++size;
    }

    // O(n)
    void remove(int idx) {
        if (idx < 0 || idx >= size)
            throw out_of_range("Index out of range");

        for (int i = idx; i < size - 1; ++i)
            data[i] = data[i + 1];

        --size;
    }

    // O(n)
    int find(int val) const {
        for (int i = 0; i < size; ++i)
            if (data[i] == val)
                return i;

        return -1;
    }

    // O(1)
    int& operator[](int idx) {
        if (idx < 0 || idx >= size)
            throw out_of_range("Index out of range");

        return data[idx];
    }

    const int& operator[](int idx) const {
        if (idx < 0 || idx >= size)
            throw out_of_range("Index out of range");

        return data[idx];
    }

    int getSize() const {
        return size;
    }

    int getCapacity() const {
        return capacity;
    }

    void print() const {
        cout << "[";
        for (int i = 0; i < size; ++i) {
            cout << data[i];
            if (i < size - 1)
                cout << ", ";
        }
        cout << "]\n";
    }
};
// ----------------------------------------------------------
//  HASH TABLE
// ----------------------------------------------------------
class HashTable {
private:
    static const int CAPACITY = 16;

    struct Slot {
        string key;
        int    value    = 0;
        bool   occupied = false;
        bool   deleted  = false;
    };

    Slot table[CAPACITY];

    int hash(const string& key) const {
        unsigned long h = 5381;
        for (char c : key)
            h = ((h << 5) + h) + c;   // djb2
        return h % CAPACITY;
    }

public:
    // Thêm / cập nhật — O(1) trung bình
    void insert(const string& key, int value) {
        int idx = hash(key);
        for (int i = 0; i < CAPACITY; i++) {
            int probe = (idx + i) % CAPACITY;
            if (!table[probe].occupied || table[probe].deleted) {
                table[probe] = {key, value, true, false};
                return;
            }
            if (table[probe].key == key) {
                table[probe].value = value;
                return;
            }
        }
        cout << "Hash table đầy!\n";
    }

    // Tìm kiếm — O(1) trung bình
    int* get(const string& key) {
        int idx = hash(key);
        for (int i = 0; i < CAPACITY; i++) {
            int probe = (idx + i) % CAPACITY;
            if (!table[probe].occupied) return nullptr;
            if (!table[probe].deleted && table[probe].key == key)
                return &table[probe].value;
        }
        return nullptr;
    }

    // Xóa — O(1) trung bình
    bool remove(const string& key) {
        int idx = hash(key);
        for (int i = 0; i < CAPACITY; i++) {
            int probe = (idx + i) % CAPACITY;
            if (!table[probe].occupied) return false;
            if (!table[probe].deleted && table[probe].key == key) {
                table[probe].deleted = true;   // tombstone
                return true;
            }
        }
        return false;
    }

    void print() const {
        for (int i = 0; i < CAPACITY; i++) {
            cout << "[" << i << "] ";
            if (!table[i].occupied || table[i].deleted)
                cout << "(rỗng)";
            else
                cout << table[i].key << " : " << table[i].value;
            cout << "\n";
        }
    }
};


// ----------------------------------------------------------
//  PRIORITY QUEUE
// ----------------------------------------------------------
class PriorityQueue {
private:
    int* data;
    int  size;
    int  capacity;

    void resize() {
        capacity *= 2;
        int* newData = new int[capacity];
        for (int i = 0; i < size; i++)
            newData[i] = data[i];
        delete[] data;
        data = newData;
    }

    // Vị trí cha / con trong heap
    int parent(int i) { return (i - 1) / 2; }
    int left  (int i) { return 2 * i + 1; }
    int right (int i) { return 2 * i + 2; }

    // Đẩy phần tử lên để đúng vị trí — O(log n)
    void heapifyUp(int i) {
        while (i > 0 && data[parent(i)] < data[i]) {
            swap(data[parent(i)], data[i]);
            i = parent(i);
        }
    }

    // Đẩy phần tử xuống để đúng vị trí — O(log n)
    void heapifyDown(int i) {
        int largest = i;
        int l = left(i), r = right(i);
        if (l < size && data[l] > data[largest]) largest = l;
        if (r < size && data[r] > data[largest]) largest = r;
        if (largest != i) {
            swap(data[i], data[largest]);
            heapifyDown(largest);
        }
    }

public:
    PriorityQueue() : size(0), capacity(4) {
        data = new int[capacity];
    }

    ~PriorityQueue() { delete[] data; }

    // Thêm phần tử — O(log n)
    void push(int val) {
        if (size == capacity) resize();
        data[size++] = val;
        heapifyUp(size - 1);
    }

    // Lấy phần tử ưu tiên cao nhất — O(1)
    int top() {
        if (size == 0) throw runtime_error("PriorityQueue rỗng!");
        return data[0];
    }

    // Xóa phần tử ưu tiên cao nhất — O(log n)
    void pop() {
        if (size == 0) return;
        data[0] = data[--size];
        heapifyDown(0);
    }

    bool empty() const { return size == 0; }
    int  getSize() const { return size; }

    void print() const {
        cout << "[";
        for (int i = 0; i < size; i++) {
            cout << data[i];
            if (i < size - 1) cout << ", ";
        }
        cout << "] (heap nội bộ)\n";
    }
};
    return 0;
}
